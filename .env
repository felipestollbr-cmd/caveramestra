# Variáveis de ambiente da Caverna Mestra
# Configure estas variáveis com suas credenciais do Supabase

# URL do seu projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima do Supabase (pública, pode ser exposta no frontend)
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Para configurar OAuth do Google e Apple:
# 1. Vá para o painel do Supabase -> Authentication -> Providers
# 2. Ative Google OAuth e configure as credenciais do Google Console
# 3. Ative Apple Sign-In e configure as credenciais da Apple
# 4. Configure os URLs de redirecionamento no Supabase